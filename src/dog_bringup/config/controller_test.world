<sdf version='1.7'>
  <world name='controller_test'>
    <light name='sun' type='directional'>
      <cast_shadows>1</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.85 0.82 0.76 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <direction>-0.45 0.25 -0.86</direction>
    </light>

    <model name='ground_plane'>
      <static>1</static>
      <link name='link'>
        <collision name='collision'>
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>60 60</size>
            </plane>
          </geometry>
          <surface>
            <friction>
              <ode>
                <mu>100</mu>
                <mu2>50</mu2>
              </ode>
            </friction>
            <contact>
              <ode>
                <kp>1000000</kp>
                <kd>100</kd>
              </ode>
            </contact>
          </surface>
        </collision>
        <visual name='visual'>
          <cast_shadows>0</cast_shadows>
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>60 60</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.52 0.56 0.58 1</ambient>
            <diffuse>0.52 0.56 0.58 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <model name='forward_reference_line'>
      <static>1</static>
      <pose>1.5 0 0.006 0 0 0</pose>
      <link name='link'>
        <visual name='visual'>
          <geometry>
            <box><size>3.0 0.03 0.01</size></box>
          </geometry>
          <material>
            <ambient>0.1 0.35 0.95 1</ambient>
            <diffuse>0.1 0.35 0.95 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <model name='yaw_test_marker'>
      <static>1</static>
      <pose>0.8 0.8 0.01 0 0 0</pose>
      <link name='link'>
        <visual name='visual'>
          <geometry>
            <cylinder><radius>0.08</radius><length>0.02</length></cylinder>
          </geometry>
          <material>
            <ambient>0.95 0.55 0.1 1</ambient>
            <diffuse>0.95 0.55 0.1 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <model name='low_step_probe'>
      <static>1</static>
      <pose>2.4 0 0.02 0 0 0</pose>
      <link name='link'>
        <collision name='collision'>
          <geometry>
            <box><size>0.35 0.9 0.04</size></box>
          </geometry>
        </collision>
        <visual name='visual'>
          <geometry>
            <box><size>0.35 0.9 0.04</size></box>
          </geometry>
          <material>
            <ambient>0.28 0.32 0.34 1</ambient>
            <diffuse>0.28 0.32 0.34 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <gravity>0 0 -9.8</gravity>
    <physics type='ode'>
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1</real_time_factor>
      <real_time_update_rate>1000</real_time_update_rate>
    </physics>
    <scene>
      <ambient>0.45 0.45 0.45 1</ambient>
      <background>0.68 0.76 0.86 1</background>
      <shadows>1</shadows>
    </scene>
    <gui fullscreen='0'>
      <camera name='user_camera'>
        <pose>3.2 -4.0 2.0 0 0.38 2.25</pose>
        <view_controller>orbit</view_controller>
        <projection_type>perspective</projection_type>
      </camera>
    </gui>
  </world>
</sdf>
